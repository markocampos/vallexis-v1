# =============================================================================
# Vallexis — Environment Variables
# Copy this file to .env and fill in the values.
# See docs/ENV.md for full documentation of every variable.
# =============================================================================

# --- api-gateway (port 3000) ---
API_PORT=3000
API_ENV=development
API_LOG_LEVEL=info
ADMIN_EMAIL=admin@vallexis.io

# IMPORTANT: Replace placeholder passwords before use. Generate with: openssl rand -hex 16
DATABASE_URL=postgres://vallexis:REPLACE_ME@localhost:5432/vallexis_db?sslmode=disable
REDIS_URL=redis://:REPLACE_ME@localhost:6379/0

JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

CORS_ALLOWED_ORIGINS=http://localhost:5173
INTERNAL_SECRET=replace_with_32_byte_hex_secret

# OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# --- deploy-service (port 3001) ---
DEPLOY_PORT=3001
DEPLOY_WORK_DIR=/tmp/builds
DEPLOY_MAX_CONCURRENT=3
DEPLOY_BUILD_TIMEOUT=300
DEPLOY_HEALTH_TIMEOUT=60
GITHUB_WEBHOOK_SECRET=replace_with_32_byte_hex_secret
# GITLAB_WEBHOOK_SECRET=
DOCKER_HOST=unix:///var/run/docker.sock
USER_CONTAINER_NETWORK=vallexis-apps
USER_CONTAINER_MEMORY_LIMIT=512m
USER_CONTAINER_CPU_QUOTA=50000

# --- payment-service (port 3002) ---
PAYMENT_PORT=3002
PAYMONGO_SECRET_KEY=sk_test_replace_me
PAYMONGO_PUBLIC_KEY=pk_test_replace_me
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_PRO_PRICE_ID=
PAYMONGO_STARTER_PRICE_ID=
# PAYMONGO_PRO_YEARLY_ID=
FRONTEND_URL=http://localhost:5173

# --- seo-service (port 3003) ---
SEO_PORT=3003
SEO_SERVICE_URL=http://seo-service:3003
CHROME_PATH=/usr/bin/chromium-browser
LIGHTHOUSE_THROTTLE=true
SEO_AUDIT_CONCURRENCY=2
SEO_AUDIT_TIMEOUT=120
SEO_SCORE_DROP_THRESHOLD=10

# --- PostgreSQL ---
POSTGRES_USER=vallexis
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=vallexis_db
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB

# --- Redis ---
REDIS_PASSWORD=REPLACE_ME
REDIS_MAX_MEMORY=256mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# --- MinIO ---
MINIO_ROOT_USER=REPLACE_ME
MINIO_ROOT_PASSWORD=REPLACE_ME
MINIO_BUCKET=vallexis
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
STORAGE_FREE_LIMIT_BYTES=2147483648
STORAGE_PRO_LIMIT_BYTES=5368709120

# --- Email (optional) ---
EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=
# RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@vallexis.io
EMAIL_FROM_NAME=Vallexis
# EMAIL_ALERTS_ADDRESS=

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3100
GRAFANA_ADMIN_USER=REPLACE_ME
GRAFANA_ADMIN_PASSWORD=REPLACE_ME
# SENTRY_DSN=

# --- Feature Flags ---
FEATURE_OAUTH_GITHUB=true
FEATURE_OAUTH_GOOGLE=true
FEATURE_CUSTOM_DOMAINS=false
FEATURE_DEPLOY_PREVIEWS=false
FEATURE_TEAM_COLLABORATION=false
FEATURE_SEO_AUDITS=true
FEATURE_MAINTENANCE_MODE=false
